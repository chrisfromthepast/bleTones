import asyncio\
from bleak import BleakScanner\
from pythonosc import udp_client\
\
# Config\
OSC_IP = "127.0.0.1"\
OSC_PORT = 57120 # Default SC Port\
OSC_ADDR = "/ble/data"\
\
client = udp_client.SimpleUDPClient(OSC_IP, OSC_PORT)\
\
def normalize_rssi(rssi):\
    # -90 (far) to -40 (close) mapped to 0.0 - 1.0\
    val = (rssi + 90) / 50 \
    return max(0.0, min(1.0, val))\
\
def detection_callback(device, advertisement_data):\
    rssi = advertisement_data.rssi\
    norm = normalize_rssi(rssi)\
    # Send ID, Name, Raw RSSI, Normalized RSSI\
    client.send_message(OSC_ADDR, [device.address, device.name or "???", rssi, norm])\
\
async def main():\
    print(f"\uc0\u55357 \u56960  Bridge Active. Sending to SC on \{OSC_PORT\}...")\
    scanner = BleakScanner(detection_callback=detection_callback)\
    async with scanner:\
        while True: await asyncio.sleep(0.1)\
\
if __name__ == "__main__":\
    try: asyncio.run(main())\
    except KeyboardInterrupt: print("\\nStopped.")\
\
