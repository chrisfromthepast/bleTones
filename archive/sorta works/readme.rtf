\pard\pardeftab720\partightenfactor0
\cf2 \cb4 \
(\
// 1. The Instrument\
SynthDef(\\bleDrone, \{\
	arg freq=220, amp=0, gate=1;\
	var sig, env;\
	// Lower, warmer sound\
	sig = VarSaw.ar([freq, freq * 1.005], 0, 0.5) * 0.15;\
	sig = LPF.ar(sig, freq * 1.5); \
	// Added 'lag' to freq for smooth glides between notes\
	freq = freq.lag(0.2); \
	env = EnvGen.kr(Env.asr(0.5, 1, 1), gate, doneAction: 2);\
	Out.ar(0, Pan2.ar(sig * env * amp.lag(0.1)));\
\}).add;\
\
// 2. Settings\
~scale = Scale.majorPentatonic;\
~activeSynths = IdentityDictionary.new;\
~rootNote = 48.midicps; // 48 is C2 (one octave lower than 60)\
\
// 3. The Listener\
OSCdef(\\bleToSound, \{\
	arg msg;\
	var id = msg[1], name = msg[2], normRSSI = msg[4];\
	var degree, freq;\
\
	if(normRSSI > 0.1, \{\
		degree = (normRSSI * 12).round;\
		freq = ~scale.degreeToFreq(degree, ~rootNote, 1);\
\
		if(~activeSynths[id].isNil, \{\
			~activeSynths[id] = Synth(\\bleDrone, [\\freq, freq, \\amp, 0]);\
		\});\
\
		~activeSynths[id].set(\\freq, freq, \\amp, normRSSI.pow(1.5));\
	\});\
\}, '/ble/data');\
\
"--- BLE Synthesizer Ready ---".postln;\
)\
