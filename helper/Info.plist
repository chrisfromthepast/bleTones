<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.chrisfromthepast.bletones-helper</string>

    <key>CFBundleName</key>
    <string>bleTones Helper</string>

    <key>CFBundleDisplayName</key>
    <string>bleTones Helper</string>

    <key>CFBundleExecutable</key>
    <string>bleTones_helper</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>LSUIElement</key>
    <true/>

    <!--
        Required by macOS 10.15+ for any process that calls CoreBluetooth.
        The helper runs as a separate app so the DAW's Info.plist is never
        modified.
    -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>bleTones Helper scans nearby Bluetooth devices and sends their
signal strength to the bleTones plugin so it can generate music.</string>

    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>bleTones Helper needs Bluetooth access to scan nearby devices.</string>
</dict>
</plist>
