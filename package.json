{
  "name": "bletones",
  "version": "1.0.0",
  "description": "A generative sound experience using Bluetooth Low Energy signals",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --dir",
    "build": "electron-builder"
  },
  "keywords": [
    "bluetooth",
    "ble",
    "audio",
    "generative",
    "music"
  ],
  "author": "chrisfromthepast",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-15"
  },
  "build": {
    "appId": "com.chrisfromthepast.bletones",
    "productName": "bleTones",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "electron.html",
      "LICENSE"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Audio"
    }
  }
}
